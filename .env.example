# Copy this file to .env.local and fill in the values.
# .env.local is gitignored. .env.example is committed.
#
# EmailJS — https://emailjs.com
# These IDs/keys are "publishable" and end up in the client bundle.
# They are NOT secrets. Abuse protection comes from EmailJS's per-domain
# rate limits and the captcha on the contact form.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Optional: hCaptcha (free, privacy-friendly spam protection)
# Setup steps:
#   1. Sign up at https://www.hcaptcha.com (free)
#   2. Add passostravel.com as a site, copy the SITE key and SECRET key
#   3. In your EmailJS dashboard: Settings -> Captcha, enable hCaptcha
#      and paste the SECRET key there
#   4. Paste the SITE key below to render the widget on the contact form
# When unset, the form falls back to honeypot + submit-rate guard only.
VITE_HCAPTCHA_SITE_KEY=
